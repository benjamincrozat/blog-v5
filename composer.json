{
    "$schema": "https://getcomposer.org/schema.json",
    "require": {
        "php": "^8.4",
        "algolia/algoliasearch-client-php": "^4.39",
        "andreiio/blade-iconoir": "^4.7",
        "blade-ui-kit/blade-heroicons": "^2.6",
        "coconutcraig/laravel-postmark": "^3.4",
        "codeat3/blade-phosphor-icons": "^2.3",
        "embed/embed": "^4.4",
        "filament/filament": "^5.3",
        "guzzlehttp/guzzle": "^7.10",
        "jaybizzle/crawler-detect": "^1.3",
        "knplabs/github-api": "^3.16",
        "lab404/laravel-impersonate": "^1.7",
        "laravel/cashier": "^16.4",
        "laravel/framework": "^12.53",
        "laravel/horizon": "^5.45",
        "laravel/scout": "^11.0",
        "laravel/socialite": "^5.25",
        "laravel/tinker": "^2.11",
        "league/flysystem-aws-s3-v3": "^3.32",
        "livewire/livewire": "^4.2",
        "openai-php/laravel": "^0.19.0",
        "sentry/sentry-laravel": "^4.20",
        "spatie/browsershot": "^5.2",
        "spatie/laravel-activitylog": "^4.12",
        "spatie/laravel-feed": "^4.5",
        "spatie/laravel-livewire-wizard": "^3.1",
        "spatie/laravel-sitemap": "^8.0",
        "tempest/highlight": "^2.17"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.16",
        "fakerphp/faker": "^1.24",
        "larastan/larastan": "^3.9",
        "laravel/pail": "^1.2",
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.8",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1",
        "pestphp/pest-plugin-livewire": "^4.1",
        "pestphp/pest-plugin-type-coverage": "^4.0",
        "spatie/laravel-db-snapshots": "^2.8",
        "spatie/ray": "^1.47"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app",
            "Database\\Factories\\": "database/factories",
            "Database\\Seeders\\": "database/seeders"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan horizon\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=horizon,logs,vite"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
